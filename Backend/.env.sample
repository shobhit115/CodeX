# Server Configuration
# [OPTIONAL] Defaults to development if not set
NODE_ENV=development
# [OPTIONAL] Port for backend server (default 5000)
PORT=5000
# [OPTIONAL] Used for internal references
SERVER_URL=http://localhost:5000
# [OPTIONAL] Allowed origins for CORS (default *)
CORS_ORIGIN=*

# Database
# [REQUIRED] MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/codex?retryWrites=true&w=majority

# Authentication (JWT & Sessions)
# [REQUIRED] Secrets for signing JWT tokens
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key
ACCESS_TOKEN_EXPIRY=10d

# Cloudinary Setup (Image Uploads)
# [REQUIRED] Cloudinary credentials for team and event images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Setup for Email
# [REQUIRED] SMTP credentials for sending OTPs and Registration updates
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@codex.com
FROM_NAME="CodeX Team"

# Default Admin Seed
# [OPTIONAL] Only used if you run the seed script to create the first admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Frontend URL (for email links)
# [REQUIRED] Used to generate certificate verification links
FRONTEND_URL=http://localhost:5173

# Bot Protection
# [OPTIONAL] Cloudflare Turnstile Secret Key (Skipped in dev if missing)
TURNSTILE_SECRET_KEY=
